geometry = st_sfc(grid, crs = st_crs(crs))
)
}
# ------------------------------------------------------------------------------
# 2. Basis function (10k columns)
# ------------------------------------------------------------------------------
make_basis_fn <- function(k = 10000L) {
force(k)
m <- ceiling(sqrt(k))
ax <- rep(seq_len(m), length.out = k)
ay <- rep(seq_len(ceiling(k / m)), each = m)[seq_len(k)]
function(coords) {
if (!is.matrix(coords) || ncol(coords) != 2L) {
stop("`coords` must be an n x 2 numeric matrix.")
}
x <- coords[, 1L]
y <- coords[, 2L]
sin(outer(x, ax)) * cos(outer(y, ay))
}
}
# ------------------------------------------------------------------------------
# 3. Full stress test
# ------------------------------------------------------------------------------
run_big_benchmark_parallel <- function(workers = max(1L, future::availableCores() - 1L)) {
future::plan(future::multisession, workers = workers)
polygons <- make_benchmark_polygons(n = 10000L)
basis_fn <- make_basis_fn(k = 10000L)
gc()
tic("10k x 10k integration benchmark (parallel)")
result <- integrate_basis(
polygons = polygons,
basis_fn = basis_fn,
n_per_triangle = 500L,
strata = NULL,
parallel_plan = "ambient"
)
timing <- toc(quiet = TRUE)
list(
elapsed_seconds = timing$toc - timing$tic,
result_dim = dim(result),
result_size_mb = as.numeric(object.size(result)) / 1024^2,
polygons_size_mb = as.numeric(object.size(polygons)) / 1024^2,
workers = workers
)
}
# ------------------------------------------------------------------------------
# 4. Run
# ------------------------------------------------------------------------------
bench <- run_big_benchmark_parallel(workers = 16L)
print(bench)
x <- rnorm(10000^2)
mean(x)
sin(x)
library(sf)
library(future)
library(tictoc)
# ------------------------------------------------------------------------------
# 1. Benchmark polygons: projected square grid
# ------------------------------------------------------------------------------
#' Construct a regular grid of square polygons in a projected CRS.
#'
#' @param n Integer. Number of polygons to keep.
#' @param cellsize Numeric. Side length of each square.
#' @param crs Integer or crs object. Projected CRS.
#'
#' @return An sf object with `n` polygons.
make_benchmark_polygons <- function(n = 1000L,
cellsize = 1000,
crs = 3857) {
m <- ceiling(sqrt(n))
bbox <- st_bbox(
c(
xmin = 0,
ymin = 0,
xmax = m * cellsize,
ymax = m * cellsize
),
crs = st_crs(crs)
)
grid <- st_make_grid(st_as_sfc(bbox), n = c(m, m), what = "polygons")
grid <- grid[seq_len(n)]
st_sf(
id = seq_len(n),
geometry = st_sfc(grid, crs = st_crs(crs))
)
}
# ------------------------------------------------------------------------------
# 2. Cheap oscillatory basis family
# ------------------------------------------------------------------------------
#' Construct a vectorized basis function bank.
#'
#' The returned function takes an n x 2 matrix of coordinates and returns
#' an n x k matrix of basis evaluations.
#'
#' @param k Integer. Number of basis functions.
#'
#' @return A function `basis_fn(coords)`.
make_basis_fn <- function(k = 1000L) {
force(k)
m <- ceiling(sqrt(k))
ax <- rep(seq_len(m), length.out = k)
ay <- rep(seq_len(ceiling(k / m)), each = m)[seq_len(k)]
function(coords) {
if (!is.matrix(coords) || ncol(coords) != 2L) {
stop("`coords` must be an n x 2 numeric matrix.")
}
x <- coords[, 1L]
y <- coords[, 2L]
sin(outer(x, ax)) * cos(outer(y, ay))
}
}
# ------------------------------------------------------------------------------
# 3. Triangle map
# ------------------------------------------------------------------------------
#' Map unit-square points to a triangle by reflection + barycentric map.
#'
#' @param qmc_points n x 2 numeric matrix in [0,1]^2.
#' @param triangle_coords 3 x 2 numeric matrix, one vertex per row.
#'
#' @return n x 2 numeric matrix of mapped coordinates.
map_unit_square_to_triangle <- function(qmc_points, triangle_coords) {
u <- qmc_points[, 1L]
v <- qmc_points[, 2L]
reflect <- (u + v > 1)
u[reflect] <- 1 - u[reflect]
v[reflect] <- 1 - v[reflect]
A <- triangle_coords[1L, ]
B <- triangle_coords[2L, ]
C <- triangle_coords[3L, ]
cbind(
(1 - u - v) * A[1L] + u * B[1L] + v * C[1L],
(1 - u - v) * A[2L] + u * B[2L] + v * C[2L]
)
}
# ------------------------------------------------------------------------------
# 4. Synthetic triangle metadata for square polygons
# ------------------------------------------------------------------------------
#' Build exact 2-triangle metadata for a square grid.
#'
#' Each square polygon is split into two triangles. This avoids any `sf`
#' geometry work inside the synthetic kernel benchmark.
#'
#' @param polygons sf polygons from `make_benchmark_polygons()`.
#'
#' @return A list with:
#'   - tri_coords: list of 3 x 2 triangle coordinate matrices
#'   - tri_area: numeric vector of triangle areas
#'   - poly_id: integer vector mapping each triangle to its polygon row
#'   - poly_area: numeric vector of polygon areas
make_square_triangle_metadata <- function(polygons) {
n <- nrow(polygons)
tri_coords <- vector("list", 2L * n)
tri_area <- numeric(2L * n)
poly_id <- rep(seq_len(n), each = 2L)
poly_area <- numeric(n)
for (i in seq_len(n)) {
bb <- st_bbox(polygons[i, ])
x0 <- unname(bb["xmin"])
x1 <- unname(bb["xmax"])
y0 <- unname(bb["ymin"])
y1 <- unname(bb["ymax"])
# Square corners
p1 <- c(x0, y0)
p2 <- c(x1, y0)
p3 <- c(x1, y1)
p4 <- c(x0, y1)
# Two triangles per square
t1 <- rbind(p1, p2, p3)
t2 <- rbind(p1, p3, p4)
tri_coords[[2L * i - 1L]] <- t1
tri_coords[[2L * i]] <- t2
area_sq <- (x1 - x0) * (y1 - y0)
poly_area[i] <- area_sq
tri_area[2L * i - 1L] <- area_sq / 2
tri_area[2L * i] <- area_sq / 2
}
list(
tri_coords = tri_coords,
tri_area = tri_area,
poly_id = poly_id,
poly_area = poly_area
)
}
# ------------------------------------------------------------------------------
# 5. Pure numeric kernel benchmark (no sf in the hot loop)
# ------------------------------------------------------------------------------
#' Integrate basis functions over polygons using precomputed triangle metadata.
#'
#' This isolates the numeric kernel:
#'   - map QMC points to triangles
#'   - evaluate basis_fn
#'   - accumulate area-weighted means by polygon
#'
#' It deliberately excludes triangulation / sf geometry work.
#'
#' @param tri_meta Output of `make_square_triangle_metadata()`.
#' @param basis_fn Function returning n x k matrix.
#' @param k_basis Integer. Number of basis columns.
#' @param n_per_triangle Integer. Number of evaluation points per triangle.
#'
#' @return Polygon-by-basis dense numeric matrix.
integrate_kernel_numeric_only <- function(tri_meta,
basis_fn,
k_basis,
n_per_triangle = 64L) {
n_poly <- length(tri_meta$poly_area)
qmc <- matrix(runif(2L * n_per_triangle), ncol = 2L)
out <- matrix(0, nrow = n_poly, ncol = k_basis)
for (i in seq_along(tri_meta$tri_coords)) {
coords <- map_unit_square_to_triangle(qmc, tri_meta$tri_coords[[i]])
vals <- basis_fn(coords)                  # n_per_triangle x k_basis
tri_mean <- colMeans(vals)                # length k_basis
out[tri_meta$poly_id[i], ] <-
out[tri_meta$poly_id[i], ] + tri_meta$tri_area[i] * tri_mean
}
out / tri_meta$poly_area
}
# ------------------------------------------------------------------------------
# 6. Timing helpers
# ------------------------------------------------------------------------------
#' Time an expression and return elapsed seconds plus result.
#'
#' @param expr Expression to evaluate.
#'
#' @return A list with `elapsed_seconds` and `value`.
time_it <- function(expr) {
gc()
t0 <- proc.time()[["elapsed"]]
val <- force(expr)
t1 <- proc.time()[["elapsed"]]
list(
elapsed_seconds = unname(t1 - t0),
value = val
)
}
#' Compute projected overall speedup using Amdahl's law.
#'
#' @param full_time Full end-to-end elapsed time.
#' @param kernel_time Numeric-kernel elapsed time.
#' @param kernel_speedup Assumed speedup factor for the kernel.
#'
#' @return Projected total speedup.
projected_speedup <- function(full_time, kernel_time, kernel_speedup) {
p <- kernel_time / full_time
1 / ((1 - p) + p / kernel_speedup)
}
# ------------------------------------------------------------------------------
# 7. Main experiment
# ------------------------------------------------------------------------------
#' Run the "is Rcpp worth it?" experiment.
#'
#' This compares:
#'   (a) current end-to-end integrate_basis()
#'   (b) synthetic pure-numeric kernel on equivalent square polygons
#'
#' Interpretation:
#'   - If the numeric-only kernel is a small fraction of total runtime,
#'     Rcpp has limited upside.
#'   - If the numeric-only kernel is a large fraction,
#'     a compiled kernel is worth serious consideration.
#'
#' @param n_polygons Integer.
#' @param k_basis Integer.
#' @param n_per_triangle Integer.
#' @param crs Projected CRS.
#'
#' @return A named list of timings and projected speedups.
run_rcpp_worth_it_experiment <- function(n_polygons = 1000L,
k_basis = 1000L,
n_per_triangle = 64L,
crs = 3857) {
future::plan(future::sequential)
polygons <- make_benchmark_polygons(
n = n_polygons,
crs = crs
)
basis_fn <- make_basis_fn(k = k_basis)
tri_meta <- make_square_triangle_metadata(polygons)
# 1. Full current pipeline
full_run <- time_it(
integrate_basis(
polygons = polygons,
basis_fn = basis_fn,
n_per_triangle = n_per_triangle,
strata = NULL
)
)
# 2. Pure numeric kernel only
kernel_run <- time_it(
integrate_kernel_numeric_only(
tri_meta = tri_meta,
basis_fn = basis_fn,
k_basis = k_basis,
n_per_triangle = n_per_triangle
)
)
full_time <- full_run$elapsed_seconds
kernel_time <- kernel_run$elapsed_seconds
kernel_share <- kernel_time / full_time
list(
full_elapsed_seconds = full_time,
kernel_elapsed_seconds = kernel_time,
kernel_share_of_full = kernel_share,
max_possible_speedup_if_kernel_were_free = 1 / (1 - kernel_share),
projected_speedup_if_kernel_2x = projected_speedup(full_time, kernel_time, 2),
projected_speedup_if_kernel_5x = projected_speedup(full_time, kernel_time, 5),
projected_speedup_if_kernel_10x = projected_speedup(full_time, kernel_time, 10),
full_result_dim = dim(full_run$value),
kernel_result_dim = dim(kernel_run$value),
full_result_size_mb = as.numeric(object.size(full_run$value)) / 1024^2,
kernel_result_size_mb = as.numeric(object.size(kernel_run$value)) / 1024^2
)
}
# ------------------------------------------------------------------------------
# 8. Example run
# ------------------------------------------------------------------------------
exp1 <- run_rcpp_worth_it_experiment(
n_polygons = 1000L,
k_basis = 1000L,
n_per_triangle = 64L,
crs = 3857
)
print(exp1)
