# test_sar_matern_matching.R
#
# Tests that the SAR and Fourier-Matern fits produce equivalent predictions
# on simulated data where the true field is known.
#
# Simulation design:
#   - 87x87 grid of 500m cells
#   - True field = smooth Matern-like spatial process (sum of low-freq cosines)
#   - ~500 irregular polygon "soundings" with additive noise
#   - Fit SAR model and Fourier-Matern model, compare predictions to truth
library(sf)
library(Matrix)
# source("sar_matern.R")
# source("fourier_integrate.R")
# source("fourier_prior.R")
library(spatintegrate)
library(fastblm)
set.seed(42)
# ==============================================================================
# 0.  Settings
# ==============================================================================
N_SIDE    <- 87L
CELLSIZE  <- 500        # metres
ORIGIN_X  <- 300000
ORIGIN_Y  <- 4600000
RHO       <- 0.99
TAU_SAR   <- 23         # SAR precision
SIGMA2_E  <- 0.01       # noise variance
N_OBS     <- 500L       # number of sounding polygons
# ==============================================================================
# 1.  Grid
# ==============================================================================
g <- sf::st_sf(geometry = sf::st_make_grid(
sf::st_as_sfc(sf::st_bbox(c(
xmin = ORIGIN_X, ymin = ORIGIN_Y,
xmax = ORIGIN_X + N_SIDE * CELLSIZE,
ymax = ORIGIN_Y + N_SIDE * CELLSIZE
), crs = 32619)),
cellsize = CELLSIZE, n = c(N_SIDE, N_SIDE), square = TRUE
))
n_cells <- nrow(g)
b           <- sf::st_bbox(g)
Lx          <- as.numeric(b["xmax"] - b["xmin"])
Ly          <- as.numeric(b["ymax"] - b["ymin"])
L           <- max(Lx, Ly)
domain_bbox <- c(b["xmin"], b["ymin"], b["xmax"], b["ymax"])
# ==============================================================================
# 2.  Simulate true field (smooth low-frequency cosine sum)
# ==============================================================================
# Cell centroids in normalised [0,1]^2 coords
cents    <- sf::st_coordinates(sf::st_centroid(g))
x_norm   <- (cents[,1] - b["xmin"]) / L
y_norm   <- (cents[,2] - b["ymin"]) / L
# True field: sum of a few low-frequency cosine modes with known coefficients
true_modes <- list(
list(kx=0, ky=1, amp= 0.5),
list(kx=1, ky=0, amp=-0.3),
list(kx=1, ky=1, amp= 0.4),
list(kx=2, ky=1, amp=-0.2),
list(kx=0, ky=2, amp= 0.3)
)
true_field <- numeric(n_cells)
for (m in true_modes) {
fx <- if (m$kx == 0) rep(1, n_cells) else sqrt(2) * cos(m$kx * pi * x_norm)
fy <- if (m$ky == 0) rep(1, n_cells) else sqrt(2) * cos(m$ky * pi * y_norm)
true_field <- true_field + m$amp * fx * fy
}
cat(sprintf("True field: mean=%.3f  sd=%.3f  range=[%.3f, %.3f]\n",
mean(true_field), sd(true_field),
min(true_field), max(true_field)))
# ==============================================================================
# 3.  Simulate sounding polygons
# ==============================================================================
# Random rectangular soundings of varying size inside the domain
make_random_sounding <- function(i) {
cx   <- runif(1, ORIGIN_X + CELLSIZE, ORIGIN_X + N_SIDE*CELLSIZE - CELLSIZE)
cy   <- runif(1, ORIGIN_Y + CELLSIZE, ORIGIN_Y + N_SIDE*CELLSIZE - CELLSIZE)
hw   <- runif(1, CELLSIZE*0.5, CELLSIZE*2.5)   # half-width
hh   <- runif(1, CELLSIZE*0.5, CELLSIZE*2.5)   # half-height
sf::st_polygon(list(matrix(c(
cx-hw, cy-hh,
cx+hw, cy-hh,
cx+hw, cy+hh,
cx-hw, cy+hh,
cx-hw, cy-hh
), ncol=2, byrow=TRUE)))
}
soundings <- sf::st_sf(
id       = seq_len(N_OBS),
geometry = sf::st_sfc(lapply(seq_len(N_OBS), make_random_sounding), crs = 32619)
)
# ==============================================================================
# 4.  Compute observations: area-weighted average of true field + noise
# ==============================================================================
# True sounding value = overlap-weighted average of true_field over each sounding
A_truth <- compute_overlap_fractions(soundings, g, parallel = FALSE)
y_true  <- as.numeric(A_truth %*% true_field)
y_obs   <- y_true + rnorm(N_OBS, 0, sqrt(SIGMA2_E))
cat(sprintf("Obs: n=%d  mean=%.3f  noise_sd=%.4f\n",
N_OBS, mean(y_obs), sqrt(SIGMA2_E)))
# ==============================================================================
# 5.  SAR fit
# ==============================================================================
cat("\n=== SAR fit ===\n")
W     <- SpatialBasis::compute_W_matrix(g, grid_shape="other", adjacency="rook")
W     <- Matrix::Matrix(W)
I_n   <- Matrix::Diagonal(n_cells)
M_sar <- I_n - RHO * W
Q_sar <- TAU_SAR * Matrix::crossprod(M_sar)
A_sar <- compute_overlap_fractions(soundings, g, parallel = FALSE)
cat(sprintf("  A_sar: %d x %d  (%.1f%% nonzero)\n",
nrow(A_sar), ncol(A_sar),
100 * nnzero(A_sar) / prod(dim(A_sar))))
fit_sar <- fit_fastblm(y = y_obs, A = A_sar, Q = Q_sar, phi = 1,
solver = "cholesky")
pred_sar <- as.numeric(fit_sar$posterior_mean)
cat(sprintf("  sigma2e=%.5f  sigma2b=%.5f\n",
fit_sar$sigma2e, fit_sar$sigma2b))
# ==============================================================================
# 6.  Fourier-Matern fit (unit-square convention)
# ==============================================================================
cat("\n=== Fourier-Matern fit ===\n")
h_norm      <- 1 / N_SIDE
params      <- get_matern_parameters_from_SAR(RHO, TAU_SAR, h = h_norm)
TAU         <- params$matern_precision
KAPPA2_NORM <- params$kappa2
cat(sprintf("  kappa2_norm=%.2f  TAU=%.4e  range=%.0fm\n",
KAPPA2_NORM, TAU, sqrt(8 / (KAPPA2_NORM / L^2))))
K        <- 2000L
MAX_FREQ <- 200L
# Use make_matern_fourier_basis just for sorted (kx,ky) indices
basis_sb <- SpatialBasis::make_matern_fourier_basis(
max_frequency = MAX_FREQ, kappa = KAPPA2_NORM, alpha = 2L,
K = K, domain = c(b["xmin"], b["xmax"], b["ymin"], b["ymax"]),
include_constant = TRUE
)
kx <- basis_sb$metadata$kx
ky <- basis_sb$metadata$ky
fg <- list(
omega_mat   = cbind(omega_x = kx * pi / L, omega_y = ky * pi / L),
norm_const  = ifelse(kx == 0L, 1, sqrt(2)) * ifelse(ky == 0L, 1, sqrt(2)),
indices     = cbind(j1 = kx + 1L, j2 = ky + 1L),
J1          = max(kx) + 1L,
J2          = max(ky) + 1L,
domain_bbox = domain_bbox,
norm        = "unit_square"
)
cat("  Computing Fourier integrals over soundings...\n")
A_fourier <- fourier_integrate_basis(soundings, fg)
na_rows   <- sum(rowSums(is.na(A_fourier)) == ncol(A_fourier))
cat(sprintf("  A_fourier: %d x %d  (%d all-NA rows)\n",
nrow(A_fourier), ncol(A_fourier), na_rows))
Q_obj   <- fourier_matern_Q_sb(fg, kappa2_norm = KAPPA2_NORM, TAU = TAU, alpha = 2L)
q_diag  <- Q_obj$q_diag
fit_fourier <- fit_fastblm(
y = y_obs, A = A_fourier, Q = Q_obj$Q, phi = 1,
solver = "woodbury", Q_inv = function(v) v / q_diag
)
cat(sprintf("  sigma2e=%.5f  sigma2b=%.5f\n",
fit_fourier$sigma2e, fit_fourier$sigma2b))
# Predict onto grid
cat("  Computing Fourier integrals over grid...\n")
A_grid_fourier <- fourier_integrate_basis(g, fg)
pred_fourier   <- as.numeric(A_grid_fourier %*% fit_fourier$posterior_mean)
# ==============================================================================
# 7.  Metrics
# ==============================================================================
cat("\n=== Prediction metrics vs truth ===\n")
r2 <- function(pred, truth) 1 - sum((pred-truth)^2) / sum((truth-mean(truth))^2)
rmse <- function(pred, truth) sqrt(mean((pred-truth)^2))
cat(sprintf("  SAR     R2=%.4f  RMSE=%.4f\n", r2(pred_sar, true_field),
rmse(pred_sar, true_field)))
cat(sprintf("  Fourier R2=%.4f  RMSE=%.4f\n", r2(pred_fourier, true_field),
rmse(pred_fourier, true_field)))
cat(sprintf("  SAR vs Fourier R2=%.6f\n", r2(pred_fourier, pred_sar)))
# ==============================================================================
# 8.  Plots
# ==============================================================================
library(ggplot2)
plot_df <- data.frame(
true_field   = true_field,
pred_sar     = pred_sar,
pred_fourier = pred_fourier
)
# 8a. SAR vs Fourier predictions
p1 <- ggplot(plot_df, aes(x = pred_fourier, y = pred_sar)) +
geom_point(alpha = 0.3, size = 0.6) +
geom_abline(slope=1, intercept=0, colour="red", linetype="dashed") +
labs(x="Fourier-Matern prediction", y="SAR prediction",
title="SAR vs Fourier-Matern predictions",
subtitle=sprintf("R²=%.4f", r2(pred_fourier, pred_sar))) +
theme_minimal(base_size=12)
# 8b. Both vs truth
p2 <- ggplot(plot_df) +
geom_point(aes(x=true_field, y=pred_sar,     colour="SAR"),
alpha=0.3, size=0.6) +
geom_point(aes(x=true_field, y=pred_fourier, colour="Fourier"),
alpha=0.3, size=0.6) +
geom_abline(slope=1, intercept=0, linetype="dashed") +
scale_colour_manual(values=c(SAR="#E74C3C", Fourier="#3498DB")) +
labs(x="True field", y="Prediction", colour="Model",
title="Predictions vs true field",
subtitle=sprintf("SAR R²=%.4f   Fourier R²=%.4f",
r2(pred_sar, true_field),
r2(pred_fourier, true_field))) +
theme_minimal(base_size=12)
# 8c. Spatial maps
g$true_field   <- true_field
g$pred_sar     <- pred_sar
g$pred_fourier <- pred_fourier
g$resid_sar    <- pred_sar     - true_field
g$resid_fourier <- pred_fourier - true_field
make_map <- function(col, title) {
ggplot(g) +
geom_sf(aes_string(fill=col), colour=NA) +
scale_fill_viridis_c(option="plasma") +
labs(title=title) +
theme_void(base_size=10) +
theme(legend.position="right")
}
p_truth   <- make_map("true_field",   "True field")
p_sar     <- make_map("pred_sar",     "SAR prediction")
p_fourier <- make_map("pred_fourier", "Fourier prediction")
p_res_sar <- make_map("resid_sar",    "SAR residual (pred - truth)")
p_res_fou <- make_map("resid_fourier","Fourier residual (pred - truth)")
# Save
ggsave("test_sar_vs_fourier_scatter.pdf",
gridExtra::grid.arrange(p1, p2, ncol=2), width=12, height=5)
ggsave("test_sar_vs_fourier_maps.pdf",
gridExtra::grid.arrange(p_truth, p_sar, p_fourier,
p_res_sar, p_res_fou, ncol=3),
width=15, height=10)
cat("\nPlots saved:\n")
cat("  test_sar_vs_fourier_scatter.pdf\n")
cat("  test_sar_vs_fourier_maps.pdf\n")
