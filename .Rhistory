#' Create a square grid centered on an sf object
#'
#' @description
#' Generates a square grid of polygons that is centered on the centroid of
#' the input `sf` object. Useful if you want symmetry around your study area
#' instead of starting the grid at the bounding-box corner.
#'
#' @param x An `sf` object (must be in a projected CRS with linear units).
#' @param cellsize Numeric. Length of one side of each square (in CRS units).
#' @param n Integer vector of length 2: number of cells in x and y directions.
#' @return An `sf` object with the grid polygons.
#' @examples
#' library(sf)
#' nc <- st_read(system.file("shape/nc.shp", package="sf")) |> st_transform(32619)
#' grid <- make_centered_grid(nc, cellsize = 50000, n = c(10, 10))
#' plot(st_geometry(grid), border = "grey")
#' plot(st_geometry(nc), add = TRUE, col = NA, border = "red")
make_centered_grid <- function(x, cellsize, n) {
stopifnot(inherits(x, "sf"))
stopifnot(length(n) == 2)
# centroid of object
ctr <- st_centroid(st_union(st_geometry(x))) |> st_coordinates()
# total span
span_x <- n[1] * cellsize
span_y <- n[2] * cellsize
# lower-left corner so grid is centered
offset_x <- ctr[1] - span_x / 2
offset_y <- ctr[2] - span_y / 2
grid <- st_make_grid(
x,
cellsize = cellsize,
n = n,
square = TRUE,
offset = c(offset_x, offset_y)
)
st_sf(geometry = grid)
}
