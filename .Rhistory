# And check what kx,ky are for columns 1 and 2
cat("mode 1: kx=", kx[1], "ky=", ky[1], "\n")
cat("mode 2: kx=", kx[2], "ky=", ky[2], "\n")
# Compare prior diagonals between the two paths
q_sb <- Matrix::diag(SpatialBasis::compute_precision(
fitted_field_matern$prepared_design$integrated_spatial_fields$resid$spatial_field$prior
))
cat("q_sb[1:6]  :", q_sb[1:6], "\n")
