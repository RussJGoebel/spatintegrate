library(spatintegrate)
library(fastblm)
library(sf)
library(Matrix)
library(spdep)
library(ggplot2)
theme_post <- function()
theme_minimal(base_size = 12) +
theme(panel.border = element_rect(fill = NA, colour = "grey70"))
set.seed(42)
domain_bbox <- c(0, 0, 10e3, 10e3)
grid_n <- 100
xy <- expand.grid(x = seq(0, 10e3, length.out = grid_n),
y = seq(0, 10e3, length.out = grid_n))
xy$truth <- sin(2*pi*xy$x/10e3) + 0.7*cos(2*pi*xy$y/10e3) +
0.4*sin(2*pi*(xy$x + xy$y)/6e3)
make_footprint <- function(cx, cy, w=1300, h=2300, deg=15) {
a <- deg*pi/180
R <- matrix(c(cos(a), -sin(a), sin(a), cos(a)), 2)
v <- matrix(c(-w/2,-h/2, w/2,-h/2, w/2,h/2, -w/2,h/2, -w/2,-h/2),
ncol=2, byrow=TRUE) %*% t(R)
v[,1] <- v[,1]+cx; v[,2] <- v[,2]+cy
sf::st_polygon(list(v))
}
n_obs <- 250
cx <- runif(n_obs, 2.5e3, 7.5e3)
cy <- runif(n_obs, 2.5e3, 7.5e3)
fps_sf <- sf::st_sf(
id       = seq_len(n_obs),
geometry = sf::st_sfc(mapply(make_footprint, cx, cy, SIMPLIFY=FALSE), crs=32619)
)
truth_sf <- sf::st_as_sf(xy, coords=c("x","y"), crs=32619)
mu <- vapply(seq_len(n_obs), function(i) {
ins <- sf::st_within(truth_sf, fps_sf[i,], sparse=FALSE)[,1]
if (!any(ins)) NA_real_ else mean(xy$truth[ins])
}, numeric(1))
keep <- !is.na(mu)
fps_sf <- fps_sf[keep,]; mu <- mu[keep]; y <- mu + rnorm(sum(keep), sd=0.15)
n_obs  <- length(y)
ggplot() +
geom_raster(data=xy, aes(x, y, fill=truth)) +
geom_sf(data=fps_sf, fill=NA, colour="white", linewidth=0.3, alpha=0.5) +
scale_fill_distiller(palette="RdYlBu") +
labs(title="Observations over the truth field",
x="Easting (m)", y="Northing (m)", fill="v(s)") +
coord_sf() + theme_post()
domain_poly <- sf::st_as_sfc(
sf::st_bbox(setNames(domain_bbox, c("xmin","ymin","xmax","ymax")), crs=32619))
sar_grid_sf <- sf::st_sf(
cell_id  = seq_along(sf::st_make_grid(domain_poly, n=c(80,80))),
geometry = sf::st_make_grid(domain_poly, n=c(80,80))
)
delta   <- sqrt(as.numeric(sf::st_area(sar_grid_sf[1,])))
n_cells <- nrow(sar_grid_sf)
cat(sprintf("Grid: 80x80 = %d cells, delta = %.0f m\n", n_cells, delta))
cat(sprintf("Footprint spans ~%.1f x %.1f cells\n", 1300/delta, 2300/delta))
A_sar <- compute_overlap_fractions(
soundings = fps_sf, fine_grid = sar_grid_sf, sparse = TRUE
)
cat("A_SAR:", nrow(A_sar), "x", ncol(A_sar), "\n")
make_rook_W <- function(grid_sf) {
nb      <- spdep::poly2nb(grid_sf, queen=FALSE)
n       <- length(nb)
i_o     <- rep(seq_len(n), lengths(nb))
j_o     <- unlist(nb, use.names=FALSE)
n_nb    <- lengths(nb)
diag_idx <- which(n_nb < 4L)
Matrix::sparseMatrix(
i = c(i_o, diag_idx), j = c(j_o, diag_idx),
x = c(rep(1/4, length(i_o)), (4L - n_nb[diag_idx])/4),
dims = c(n, n)
)
}
make_sar_Q <- function(grid_sf, rho) {
W <- make_rook_W(grid_sf)
Matrix::crossprod(Matrix::Diagonal(nrow(W)) - rho*W)
}
rho_grid  <- c(0.85, 0.90, 0.95, 0.97, 0.99)
set.seed(1)
folds     <- sample(rep(1:5, length.out=n_obs))
cv_score <- function(rho) {
Q     <- make_sar_Q(sar_grid_sf, rho)
Q_inv <- function(v) as.numeric(Matrix::solve(Q, v))
scores <- vapply(1:5, function(k) {
tr <- which(folds != k); te <- which(folds == k)
A_tr <- A_sar[tr, ]; y_tr <- y[tr]; A_te <- A_sar[te, ]
# Profile phi via a simple grid then fit
phi_best <- 3.0
best_mse <- Inf
for (phi_try in c(0.5, 1, 3, 10, 30)) {
fit_try <- fit_fastblm(y_tr, A_tr, Q, phi=phi_try,
solver="woodbury", Q_inv=Q_inv)
mse_try <- mean((A_te %*% fit_try$posterior_mean - y[te])^2)
if (mse_try < best_mse) { best_mse <- mse_try; phi_best <- phi_try }
}
best_mse
}, numeric(1))
mean(scores)
}
cv_results <- data.frame(
rho   = rho_grid,
cv_mse = vapply(rho_grid, cv_score, numeric(1))
)
print(cv_results)
rho_hat <- cv_results$rho[which.min(cv_results$cv_mse)]
cat("Best rho:", rho_hat, "\n")
Q_sar      <- make_sar_Q(sar_grid_sf, rho_hat)
Q_inv_sar  <- function(v) as.numeric(Matrix::solve(Q_sar, v))
fit_sar    <- fit_fastblm(y, A_sar, Q_sar, phi=3,
solver="woodbury", Q_inv=Q_inv_sar)
# Refine phi
phi_hat    <- fit_sar$sigma2b / fit_sar$sigma2e
fit_sar    <- fit_fastblm(y, A_sar, Q_sar, phi=phi_hat,
solver="woodbury", Q_inv=Q_inv_sar)
fitted_sar <- as.numeric(A_sar %*% fit_sar$posterior_mean)
cat(sprintf("SAR fit: rho=%.2f, phi=%.3g\n", rho_hat, phi_hat))
fg        <- fourier_freq_grid(J=80, domain_bbox=domain_bbox)
A_fourier <- fourier_integrate_basis(fps_sf, fg)
cat("A_Fourier:", nrow(A_fourier), "x", ncol(A_fourier), "\n")
Q_fourier <- fourier_sar_Q_fun(freq_grid=fg, delta=delta)(
c(logit_rho=qlogis(rho_hat), log_tau2=log(1))
)$Q
Q_inv_fourier <- Matrix::Diagonal(x=1/Matrix::diag(Q_fourier))
fit_fourier    <- fit_fastblm(y, A_fourier, Q_fourier, phi=phi_hat,
solver="woodbury", Q_inv=Q_inv_fourier)
fitted_fourier <- as.numeric(A_fourier %*% fit_fourier$posterior_mean)
df <- data.frame(sar=fitted_sar, fourier=fitted_fourier)
ggplot(df, aes(sar, fourier)) +
geom_point(alpha=0.5, size=1.5) +
geom_abline(slope=1, intercept=0, linetype=2, colour="steelblue") +
coord_equal() +
labs(title="Fitted footprint means: SAR-raster vs Fourier-SAR",
subtitle="Same parameters, different basis — near-identical fits",
x="SAR-raster", y="Fourier-SAR") +
theme_post()
J_values <- c(10, 20, 40, 60, 80)
sens <- lapply(J_values, function(J_now) {
fg_now    <- fourier_freq_grid(J=J_now, domain_bbox=domain_bbox)
A_now     <- fourier_integrate_basis(fps_sf, fg_now)
Q_now     <- fourier_sar_Q_fun(freq_grid=fg_now, delta=delta)(
c(logit_rho=qlogis(rho_hat), log_tau2=log(1))
)$Q
Q_inv_now <- Matrix::Diagonal(x=1/Matrix::diag(Q_now))
fit_now   <- fit_fastblm(y, A_now, Q_now, phi=phi_hat,
solver="woodbury", Q_inv=Q_inv_now)
fitted_now <- as.numeric(A_now %*% fit_now$posterior_mean)
data.frame(J=J_now, n_basis=J_now^2,
rmse_vs_sar=sqrt(mean((fitted_now - fitted_sar)^2)))
})
sens_df <- do.call(rbind, sens)
knitr::kable(sens_df, digits=4,
caption="RMSE vs SAR-raster as J increases")
ggplot(sens_df, aes(n_basis, rmse_vs_sar)) +
geom_line(colour="steelblue") + geom_point(colour="steelblue", size=3) +
labs(title="Predictions stabilise as J increases",
x="Number of basis functions (J²)",
y="RMSE vs SAR-raster") +
theme_post()
fourier_evaluate <- function(coords, fg) {
ox <- fg$omega_mat[,1]; oy <- fg$omega_mat[,2]; nc <- fg$norm_const
sx <- as.matrix(coords)[,1]; sy <- as.matrix(coords)[,2]
sweep(cos(outer(sx,ox)) * cos(outer(sy,oy)), 2, nc, `*`)
}
# Three resolutions from the same fitted coefficients
grids <- list(
"Coarse (50x50)"  = expand.grid(x=seq(0,10e3,length.out=50),
y=seq(0,10e3,length.out=50)),
"Medium (100x100)" = expand.grid(x=seq(0,10e3,length.out=100),
y=seq(0,10e3,length.out=100)),
"Fine (200x200)"  = expand.grid(x=seq(0,10e3,length.out=200),
y=seq(0,10e3,length.out=200))
)
pred_list <- lapply(grids, function(g) {
Phi  <- fourier_evaluate(g, fg)
pred <- as.numeric(Phi %*% fit_fourier$posterior_mean)
cbind(g, pred=pred)
})
pred_df <- do.call(rbind, Map(function(nm, df) cbind(df, res=nm),
names(pred_list), pred_list))
ggplot(pred_df, aes(x, y, fill=pred)) +
geom_raster() +
facet_wrap(~res, ncol=1) +
scale_fill_distiller(palette="RdYlBu") +
coord_equal() +
labs(title="Fourier-SAR posterior mean at three resolutions",
subtitle="Same fitted coefficients — no refitting",
x="Easting (m)", y="Northing (m)", fill="v̂(s)") +
theme_post()
knitr::opts_chunk$set(
collapse = TRUE, comment = "#>",
fig.width = 7, fig.height = 4.5, dpi = 150,
message = FALSE, warning = FALSE
)
library(spatintegrate)
library(fastblm)
library(sf)
library(Matrix)
library(spdep)
library(ggplot2)
library(future)
library(future.apply)
theme_post <- function()
theme_minimal(base_size = 12) +
theme(panel.border = element_rect(fill = NA, colour = "grey70"))
set.seed(42)
domain_bbox <- c(0, 0, 10e3, 10e3)
grid_n <- 100
xy <- expand.grid(x = seq(0, 10e3, length.out = grid_n),
y = seq(0, 10e3, length.out = grid_n))
xy$truth <- sin(2*pi*xy$x/10e3) + 0.7*cos(2*pi*xy$y/10e3) +
0.4*sin(2*pi*(xy$x + xy$y)/6e3)
make_footprint <- function(cx, cy, w=1300, h=2300, deg=15) {
a <- deg*pi/180
R <- matrix(c(cos(a), -sin(a), sin(a), cos(a)), 2)
v <- matrix(c(-w/2,-h/2, w/2,-h/2, w/2,h/2, -w/2,h/2, -w/2,-h/2),
ncol=2, byrow=TRUE) %*% t(R)
v[,1] <- v[,1]+cx; v[,2] <- v[,2]+cy
sf::st_polygon(list(v))
}
n_obs <- 250
cx <- runif(n_obs, 2.5e3, 7.5e3)
cy <- runif(n_obs, 2.5e3, 7.5e3)
fps_sf <- sf::st_sf(
id       = seq_len(n_obs),
geometry = sf::st_sfc(mapply(make_footprint, cx, cy, SIMPLIFY=FALSE), crs=32619)
)
truth_sf <- sf::st_as_sf(xy, coords=c("x","y"), crs=32619)
mu <- vapply(seq_len(n_obs), function(i) {
ins <- sf::st_within(truth_sf, fps_sf[i,], sparse=FALSE)[,1]
if (!any(ins)) NA_real_ else mean(xy$truth[ins])
}, numeric(1))
