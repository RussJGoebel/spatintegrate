# The effective regularisation per mode is Q/||A_k||^2
# If Q[k] << ||A_k||^2, the mode is data-driven and amplifies A differences
col_norm_exact <- colSums(A_fourier_obs^2, na.rm=TRUE)
col_norm_qmc   <- colSums(A_qmc^2, na.rm=TRUE)
snr <- col_norm_exact / q_diag   # signal-to-noise per mode
plot(lambda_norm, snr, log="xy",
xlab="lambda", ylab="||A_k||^2 / q_k",
main="Effective SNR per mode")
abline(h=1, col="red")
cat("col_norm exact vs QMC at high freq:\n")
cat("  exact last 6:", tail(col_norm_exact, 6), "\n")
cat("  QMC   last 6:", tail(col_norm_qmc,   6), "\n")
cat("  ratio (exact/QMC) last 6:", tail(col_norm_exact/col_norm_qmc, 6), "\n")
cat("  ratio (exact/QMC) first 6:", head(col_norm_exact/col_norm_qmc, 6), "\n")
# A_k'y for exact vs QMC at high and low frequencies
Aty_exact <- as.numeric(crossprod(A_fourier_obs, y))
Aty_qmc   <- as.numeric(crossprod(A_qmc, y))
cat("Aty_exact first 6:", head(Aty_exact, 6), "\n")
cat("Aty_qmc   first 6:", head(Aty_qmc,   6), "\n")
cat("Aty_exact last 6:", tail(Aty_exact, 6), "\n")
cat("Aty_qmc   last 6:", tail(Aty_qmc,   6), "\n")
cat("\nratio Aty_exact/Aty_qmc first 6:", head(Aty_exact/Aty_qmc, 6), "\n")
cat("ratio Aty_exact/Aty_qmc last 6:",  tail(Aty_exact/Aty_qmc, 6), "\n")
