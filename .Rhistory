knitr::opts_chunk$set(
collapse = TRUE,
comment  = "#>",
fig.width  = 5,
fig.height = 5
)
library(sf)
library(ggplot2)
library(spatintegrate)  # provides compute_overlap_fractions()
make_cell <- function(x0, y0, size = 1) {
st_polygon(list(matrix(
c(x0,      y0,
x0+size, y0,
x0+size, y0+size,
x0,      y0+size,
x0,      y0),
ncol = 2, byrow = TRUE
)))
}
cells <- vector("list", 9)
k     <- 1L
for (row in 0:2) {
for (col in 0:2) {
cells[[k]] <- make_cell(col, row)
k <- k + 1L
}
}
fine_grid <- st_sf(
cell = paste0("(", rep(0:2, each = 3), ",", rep(0:2, 3), ")"),
geometry = st_sfc(cells, crs = 32619)
)
diamond <- st_polygon(list(matrix(
c(1.5, 3.0,   # top
3.0, 1.5,   # right
1.5, 0.0,   # bottom
0.0, 1.5,   # left
1.5, 3.0),  # close
ncol = 2, byrow = TRUE
)))
soundings <- st_sf(
sounding = "diamond",
geometry = st_sfc(diamond, crs = 32619)
)
A <- compute_overlap_fractions(soundings, fine_grid)
A
A
round(Matrix::rowSums(A), 10)
---
title: "Computing overlap fractions between soundings and a fine grid"
knitr::opts_chunk$set(
collapse = TRUE,
comment  = "#>",
fig.width  = 5,
fig.height = 5
)
library(sf)
library(ggplot2)
library(spatintegrate)  # provides compute_overlap_fractions()
make_cell <- function(x0, y0, size = 1) {
st_polygon(list(matrix(
c(x0,      y0,
x0+size, y0,
x0+size, y0+size,
x0,      y0+size,
x0,      y0),
ncol = 2, byrow = TRUE
)))
}
cells <- vector("list", 9)
k     <- 1L
for (row in 0:2) {
for (col in 0:2) {
cells[[k]] <- make_cell(col, row)
k <- k + 1L
}
}
fine_grid <- st_sf(
cell = paste0("(", rep(0:2, each = 3), ",", rep(0:2, 3), ")"),
geometry = st_sfc(cells, crs = 32619)
)
diamond <- st_polygon(list(matrix(
c(1.5, 3.0,   # top
3.0, 1.5,   # right
1.5, 0.0,   # bottom
0.0, 1.5,   # left
1.5, 3.0),  # close
ncol = 2, byrow = TRUE
)))
soundings <- st_sf(
sounding = "diamond",
geometry = st_sfc(diamond, crs = 32619)
)
st_area(soundings)  # 4.5 square units
A <- compute_overlap_fractions(soundings, fine_grid)
A
round(Matrix::rowSums(A), 10)
# A is 1 x 9; pull out the single row
fine_grid$fraction <- as.numeric(A[1, ])
# Sounding boundary for overlay
sounding_outline <- st_cast(st_geometry(soundings), "MULTILINESTRING")
ggplot() +
geom_sf(
data  = fine_grid,
aes(fill = fraction),
colour = "grey40",
linewidth = 0.4
) +
geom_sf(
data      = soundings,
fill      = NA,
colour    = "#0F6E56",
linewidth = 0.8,
linetype  = "dashed"
) +
geom_sf_text(
data  = fine_grid,
aes(label = ifelse(fraction > 0, round(fraction, 3), "0")),
size  = 3.5,
colour = "grey20"
) +
scale_fill_distiller(
palette  = "Greens",
direction = 1,
limits   = c(0, 1),
name     = "Overlap\nfraction"
) +
labs(
title    = "Overlap fractions: diamond sounding over 3 × 3 grid",
subtitle = "Each label shows A[1, j] = |sounding ∩ cell j| / |sounding|",
x        = NULL,
y        = NULL
) +
theme_minimal(base_size = 11) +
theme(
panel.grid      = element_blank(),
axis.text       = element_blank(),
plot.title      = element_text(size = 11, face = "bold"),
plot.subtitle   = element_text(size = 9, colour = "grey40"),
legend.position = "right"
)
# A is already a sparse Matrix by default — inspect its structure
Matrix::image(A)
cat("Dimensions:", nrow(A), "soundings ×", ncol(A), "cells\n")
cat("Non-zero entries:", Matrix::nnzero(A), "\n")
cat("Sparsity:", round(1 - Matrix::nnzero(A) / prod(dim(A)), 3), "\n")
View(cells)
