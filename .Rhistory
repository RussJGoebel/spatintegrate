sar_prior <- SpatialBasis::make_sar_prior(geom_basis,tau = sar_precision_val,adjacency ="rook")
residual_field <- make_spatial_field(basis = geom_basis,
prior = sar_prior,
integration_rule = integration_rule_area_overlap(),
label = "resid")
prepared_design <- SpatialBasis::prepare_spatial_design(residual_field,observation_data = soundings_proj)
fitted_field <- fit_spatial_field(prepared_design,response = "synthetic_albedo")
# Trying to match the prior from rho = 0.99, scale = sar_precision_val
# Trying to match the prior from rho = 0.99, tau = sar_precision_val (variance = 1/sar_precision_val)
get_matern_parameters_from_SAR <- function(rho, sar_precision, h, d = 2) {
# Step 1: Compute SAR variance
sar_variance <- 1 / sar_precision
# Step 2: Match variance scaling to Matérn
# The key result from spectral matching is:
#   sigma_matern^2 ≈ sigma_sar^2 / [(2d / (rho h^2))^2]
matern_variance <-  sar_variance * ((2 * d / (rho * h)))^2
matern_precision <- 1 / matern_variance
# Step 3: Match kappa^2 to effective Laplacian scale
kappa2 <- 2 * d  * (1 - rho) / rho / h^2
return(list(
matern_precision = matern_precision,
kappa2 = kappa2
))
}
b <- sf::st_bbox(g)
domain <- c(b[1],b[3],b[2],b[4])
#mult precision by 87 to get good fit?
prior_param <- get_matern_parameters_from_SAR(rho = 0.99, sar_precision = sar_precision_val, h = 1/87)
matern_basis <- SpatialBasis::make_matern_fourier_basis(max_frequency = 1000, kappa = prior_param$kappa2,alpha = 2, K = 10000, domain = domain)
matern_prior <- SpatialBasis::make_matern_fourier_prior(matern_basis,tau = prior_param$matern_precision, kappa2 = prior_param$kappa2,alpha = 2)
residual_field <- make_spatial_field(basis = matern_basis,
prior = matern_prior,
integration_rule = integration_rule_qmc_average(generate_qmc_unit_square(256)),
label = "resid")
